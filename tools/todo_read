#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///

import json
import os
import sys
from pathlib import Path
from typing import Any


TOOL_NAME = "todo_read"

DESCRIPTION = {
    "name": TOOL_NAME,
    "description": "Read the current todo list managed by the companion todo_write custom tool.",
    "input_schema": {
        "type": "object",
        "properties": {},
        "additionalProperties": False,
    },
}

STATUS_ORDER = {
    "canceled": 0,
    "completed": 1,
    "in_progress": 2,
    "pending": 3,
}
PRIORITY_ORDER = {
    "high": 0,
    "medium": 1,
    "low": 2,
}


def emit_json(payload: dict[str, Any]) -> None:
    print(json.dumps(payload, indent=2, ensure_ascii=False))


def emit_error(message: str) -> int:
    emit_json({"error": message})
    return 1


def todo_dir() -> Path:
    raw_path = os.environ.get("CUSTOM_TOOL_TODO_DIR")
    if not raw_path:
        return Path.home() / ".kodelet" / "todos" / "custom-tools"
    path = Path(raw_path).expanduser()
    if not path.is_absolute():
        path = Path.cwd() / path
    return path.resolve()


def resolve_todo_file() -> Path:
    conversation_id = os.environ.get("KODELET_CONVERSATION_ID", "").strip()
    if not conversation_id:
        raise ValueError("KODELET_CONVERSATION_ID is required")
    return todo_dir() / f"{conversation_id}.json"


def load_payload(raw_input: str) -> dict[str, Any]:
    if not raw_input.strip():
        return {}
    payload = json.loads(raw_input)
    if not isinstance(payload, dict):
        raise ValueError("input must be a JSON object")
    return payload


def sort_todos(todos: list[dict[str, Any]]) -> list[dict[str, Any]]:
    return sorted(
        todos,
        key=lambda todo: (
            STATUS_ORDER.get(str(todo.get("status", "")), 99),
            PRIORITY_ORDER.get(str(todo.get("priority", "")), 99),
        ),
    )


def calculate_statistics(todos: list[dict[str, Any]]) -> dict[str, int]:
    stats = {"total": len(todos), "completed": 0, "in_progress": 0, "pending": 0, "canceled": 0}
    for todo in todos:
        status = todo.get("status")
        if status in stats:
            stats[status] += 1
    return stats


def run_tool() -> int:
    try:
        load_payload(sys.stdin.read())
        todo_file = resolve_todo_file()
    except json.JSONDecodeError as exc:
        return emit_error(f"invalid JSON input: {exc}")
    except ValueError as exc:
        return emit_error(str(exc))

    try:
        with todo_file.open("r", encoding="utf-8") as handle:
            stored = json.load(handle)
    except FileNotFoundError:
        return emit_error(f"todo file not found: {todo_file}")
    except json.JSONDecodeError as exc:
        return emit_error(f"failed to parse todo file {todo_file}: {exc}")
    except OSError as exc:
        return emit_error(f"failed to read todo file {todo_file}: {exc}")

    todos = stored.get("todos") if isinstance(stored, dict) else None
    if not isinstance(todos, list):
        return emit_error(f"todo file has invalid format: {todo_file}")

    sorted_todos = sort_todos(todos)
    emit_json(
        {
            "status": "success",
            "file_path": str(todo_file),
            "todos": sorted_todos,
            "statistics": calculate_statistics(todos),
        }
    )
    return 0


def main(argv: list[str]) -> int:
    if len(argv) != 2 or argv[1] not in {"description", "run"}:
        print(f"Usage: {Path(argv[0]).name} [description|run]", file=sys.stderr)
        return 1
    if argv[1] == "description":
        emit_json(DESCRIPTION)
        return 0
    return run_tool()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
