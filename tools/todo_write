#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///

import json
import os
import sys
from pathlib import Path
from typing import Any


TOOL_NAME = "todo_write"
VALID_STATUSES = {"pending", "in_progress", "completed", "canceled"}
VALID_PRIORITIES = {"high", "medium", "low"}

DESCRIPTION = {
    "name": TOOL_NAME,
    "description": "Create or update the todo list for the current task.",
    "input_schema": {
        "type": "object",
        "properties": {
            "todos": {
                "type": "array",
                "description": "The full todo list, including pending, in_progress, completed, and canceled items.",
                "items": {
                    "type": "object",
                    "properties": {
                        "content": {
                            "type": "string",
                            "description": "The content of the todo in 1-2 sentences.",
                        },
                        "status": {
                            "type": "string",
                            "enum": sorted(VALID_STATUSES),
                            "description": "The status of the todo.",
                        },
                        "priority": {
                            "type": "string",
                            "enum": sorted(VALID_PRIORITIES),
                            "description": "The priority of the todo.",
                        },
                    },
                    "required": ["content", "status", "priority"],
                    "additionalProperties": False,
                },
            },
        },
        "required": ["todos"],
        "additionalProperties": False,
    },
}


def emit_json(payload: dict[str, Any]) -> None:
    print(json.dumps(payload, indent=2, ensure_ascii=False))


def emit_error(message: str) -> int:
    emit_json({"error": message})
    return 1


def todo_dir() -> Path:
    raw_path = os.environ.get("CUSTOM_TOOL_TODO_DIR")
    if not raw_path:
        return Path.home() / ".kodelet" / "todos" / "custom-tools"
    path = Path(raw_path).expanduser()
    if not path.is_absolute():
        path = Path.cwd() / path
    return path.resolve()


def resolve_todo_file() -> Path:
    conversation_id = os.environ.get("KODELET_CONVERSATION_ID", "").strip()
    if not conversation_id:
        raise ValueError("KODELET_CONVERSATION_ID is required")
    return todo_dir() / f"{conversation_id}.json"


def load_payload(raw_input: str) -> dict[str, Any]:
    payload = json.loads(raw_input or "{}")
    if not isinstance(payload, dict):
        raise ValueError("input must be a JSON object")
    return payload


def validate_todos(payload: dict[str, Any]) -> list[dict[str, str]]:
    todos = payload.get("todos")
    if not isinstance(todos, list):
        raise ValueError("todos is required and must be an array")
    if len(todos) == 0:
        raise ValueError("todos should have at least one todo")

    validated: list[dict[str, str]] = []
    for index, todo in enumerate(todos):
        if not isinstance(todo, dict):
            raise ValueError(f"todo {index} must be an object")

        content = todo.get("content")
        status = todo.get("status")
        priority = todo.get("priority")

        if not isinstance(content, str) or not content.strip():
            raise ValueError(f"todo {index} content is required")
        if status not in VALID_STATUSES:
            raise ValueError(f"todo {index} status must be one of {sorted(VALID_STATUSES)}")
        if priority not in VALID_PRIORITIES:
            raise ValueError(f"todo {index} priority must be one of {sorted(VALID_PRIORITIES)}")

        validated.append(
            {
                "content": content.strip(),
                "status": str(status),
                "priority": str(priority),
            }
        )
    return validated


def calculate_statistics(todos: list[dict[str, str]]) -> dict[str, int]:
    stats = {"total": len(todos), "completed": 0, "in_progress": 0, "pending": 0, "canceled": 0}
    for todo in todos:
        stats[todo["status"]] += 1
    return stats


def run_tool() -> int:
    try:
        payload = load_payload(sys.stdin.read())
        todos = validate_todos(payload)
        todo_file = resolve_todo_file()
    except json.JSONDecodeError as exc:
        return emit_error(f"invalid JSON input: {exc}")
    except ValueError as exc:
        return emit_error(str(exc))

    try:
        todo_file.parent.mkdir(parents=True, exist_ok=True)
        todo_file.write_text(json.dumps({"todos": todos}, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    except OSError as exc:
        return emit_error(f"failed to write todos to {todo_file}: {exc}")

    emit_json(
        {
            "status": "success",
            "file_path": str(todo_file),
            "message": f"Todos have been written to {todo_file}",
            "todos": todos,
            "statistics": calculate_statistics(todos),
        }
    )
    return 0


def main(argv: list[str]) -> int:
    if len(argv) != 2 or argv[1] not in {"description", "run"}:
        print(f"Usage: {Path(argv[0]).name} [description|run]", file=sys.stderr)
        return 1
    if argv[1] == "description":
        emit_json(DESCRIPTION)
        return 0
    return run_tool()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
