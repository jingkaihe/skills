#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# ///

from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path
from typing import Any
from urllib.error import HTTPError, URLError
from urllib.parse import unquote, urlparse
from urllib.request import HTTPRedirectHandler, Request, build_opener

TOOL_NAME = "image_recognition"
DESCRIPTION = "Analyze an image with a vision model."
SUPPORTED_EXTENSIONS = {".jpg", ".jpeg", ".png", ".gif", ".webp"}
MAX_IMAGE_SIZE_BYTES = 5 * 1024 * 1024
REMOTE_HEAD_TIMEOUT_SECONDS = 15
SUBPROCESS_TIMEOUT_SECONDS = 110


class NoRedirectHandler(HTTPRedirectHandler):
    def redirect_request(self, req, fp, code, msg, headers, newurl):  # type: ignore[override]
        return None


def get_description() -> dict[str, Any]:
    return {
        "name": TOOL_NAME,
        "description": DESCRIPTION,
        "input_schema": {
            "type": "object",
            "properties": {
                "image_path": {
                    "type": "string",
                    "description": "The path to the image to be recognized. It can be a local file 'file:///path/to/image.jpg' or a remote file 'https://example.com/image.jpg'.",
                },
                "prompt": {
                    "type": "string",
                    "description": "The information you want to extract from the image.",
                },
            },
            "required": ["image_path", "prompt"],
        },
    }


def fail(message: str, *, exit_code: int = 1) -> None:
    print(message, file=sys.stderr)
    sys.exit(exit_code)


def ensure_non_empty_string(value: Any, field_name: str) -> str:
    if not isinstance(value, str) or not value.strip():
        fail(f"Missing required parameter: {field_name}")
    return value.strip()


def normalize_local_path(raw_path: str) -> Path:
    parsed = urlparse(raw_path)
    if parsed.scheme == "file":
        if parsed.netloc not in {"", "localhost"}:
            fail(f"Unsupported file URI host: {parsed.netloc}")
        path = Path(unquote(parsed.path))
    else:
        path = Path(raw_path)

    if not path.is_absolute():
        path = (Path.cwd() / path).resolve()
    else:
        path = path.resolve()

    return path


def validate_local_image(path: Path) -> str:
    if not path.exists():
        fail(f"image file not found: {path}")
    if not path.is_file():
        fail(f"image path is not a file: {path}")

    extension = path.suffix.lower()
    if extension not in SUPPORTED_EXTENSIONS:
        fail(
            "unsupported image format: "
            f"{extension or '<none>'} (supported: {sorted(SUPPORTED_EXTENSIONS)})"
        )

    size = path.stat().st_size
    if size > MAX_IMAGE_SIZE_BYTES:
        fail(f"image file too large: {size} bytes (max: 5MB)")

    return str(path)


def validate_remote_image(image_url: str) -> str:
    parsed = urlparse(image_url)
    if parsed.scheme != "https":
        fail("only HTTPS URLs are supported for security")
    if not parsed.netloc:
        fail("invalid HTTPS URL")

    opener = build_opener(NoRedirectHandler)
    request = Request(image_url, method="HEAD")

    try:
        with opener.open(request, timeout=REMOTE_HEAD_TIMEOUT_SECONDS) as response:
            status = getattr(response, "status", response.getcode())
            if status < 200 or status >= 300:
                fail(f"HTTP error: {status}")

            content_type = response.headers.get("Content-Type")
            if content_type and not content_type.startswith("image/"):
                fail(f"URL does not point to an image (Content-Type: {content_type})")

            content_length = response.headers.get("Content-Length")
            if content_length:
                try:
                    size = int(content_length)
                except ValueError:
                    size = None
                if size is not None and size > MAX_IMAGE_SIZE_BYTES:
                    fail(f"image file too large: {size} bytes (max: 5MB)")
    except HTTPError as exc:
        if 300 <= exc.code < 400:
            fail("redirects are not allowed for remote images")
        fail(f"failed to access image URL: HTTP {exc.code} {exc.reason}")
    except URLError as exc:
        fail(f"failed to access image URL: {exc.reason}")

    return image_url


def normalize_and_validate_image_path(image_path: str) -> str:
    if image_path.startswith("http://"):
        fail("only HTTPS URLs are supported for security")
    if image_path.startswith("https://"):
        return validate_remote_image(image_path)
    return validate_local_image(normalize_local_path(image_path))


def build_analysis_prompt(prompt: str) -> str:
    return f"""Examine the image and respond to the request below.

<request>
{prompt}
</request>

Focus only on information relevant to the request:
- State observable facts, not assumptions
- Quote visible text, labels, or annotations exactly when relevant
- Describe layout and relationships between key elements
- Highlight technical details when applicable (UI components, architecture patterns, data flows)
- Clearly note anything unclear or ambiguous

Keep the response clear and actionable."""


def run_kodelet(image_path: str, prompt: str) -> str:
    analysis_prompt = build_analysis_prompt(prompt)

    command = [
        "kodelet",
        "run",
        "--as-subagent",
        "--use-weak-model",
        "--result-only",
        "--no-save",
        "--no-tools",
        "--no-mcp",
        "--no-skills",
        "--no-workflows",
        "--no-hooks",
        "--log-level",
        "error",
        "--image",
        image_path,
        analysis_prompt,
    ]

    try:
        completed = subprocess.run(
            command,
            capture_output=True,
            text=True,
            timeout=SUBPROCESS_TIMEOUT_SECONDS,
            check=False,
        )
    except subprocess.TimeoutExpired:
        fail(f"image recognition timed out after {SUBPROCESS_TIMEOUT_SECONDS} seconds")

    if completed.returncode != 0:
        details = completed.stderr.strip() or completed.stdout.strip() or f"exit code {completed.returncode}"
        fail(f"image recognition failed: {details}")

    result = completed.stdout.strip()
    if not result:
        fail("image recognition failed: kodelet returned an empty response")

    return result


def run_tool() -> None:
    try:
        input_data = json.load(sys.stdin)
    except json.JSONDecodeError as exc:
        fail(f"Invalid JSON input: {exc}")

    image_path = ensure_non_empty_string(input_data.get("image_path"), "image_path")
    prompt = ensure_non_empty_string(input_data.get("prompt"), "prompt")

    normalized_image_path = normalize_and_validate_image_path(image_path)
    result = run_kodelet(normalized_image_path, prompt)
    print(result)


def main() -> None:
    if len(sys.argv) != 2:
        print(f"Usage: {TOOL_NAME} [description|run]", file=sys.stderr)
        sys.exit(1)

    command = sys.argv[1]
    if command == "description":
        print(json.dumps(get_description(), indent=2))
    elif command == "run":
        run_tool()
    else:
        print(f"Unknown command: {command}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
